# Telegram Bot Token — get from @BotFather: https://t.me/BotFather
TELEGRAM_TOKEN=your_telegram_bot_token_here

# Ollama URL
# If Ollama runs on Windows host, use the Windows machine IP
# Find it on Ubuntu with: ip route | grep default | awk '{print $3}'
OLLAMA_URL=http://172.17.0.1:11434

# n8n Webhook URLs
# After importing n8n_webhooks_workflow.json, copy Production URLs from each webhook node
N8N_SEND_WEBHOOK=https://your-n8n-domain/webhook/send-application
N8N_DRAFT_WEBHOOK=https://your-n8n-domain/webhook/draft-application
N8N_SHEETS_WEBHOOK=https://your-n8n-domain/webhook/log-sheets
